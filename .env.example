# Dominion Empire — Production Environment Variables
# =====================================================
# Location on prod VM: ~/desktop-tutorial/.env
# Docker Compose reads this automatically at startup.
# NEVER commit a filled-in version of this file.
# =====================================================

# --- Gumroad (Divine Sovereignty checkout) ---
GUMROAD_TOKEN=

# --- Brevo Email ---
BREVO_API_KEY=
DEFAULT_FROM_EMAIL=noreply@dominionhealing.org
DEFAULT_FROM_NAME=Dominion Healing

# --- YouTube ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_API_KEY=

# --- OANDA Trading ---
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
OANDA_ENV=practice

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- TikTok ---
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# --- n8n Gateway ---
N8N_WEBHOOK_BASE=
N8N_WEBHOOK_PATH=/webhook/clean2
N8N_TOOL_SECRET=
AGENT_HMAC_SECRET=

# --- Shopify (optional) ---
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_WEBHOOK_SECRET=

# --- Claude / AI ---
ANTHROPIC_API_KEY=
